{
  "provider": "openai",
  "api_key": "your-api-key-here"
}

// Examples for different providers:
//
// OpenAI:
// {
//   "provider": "openai",
//   "api_key": "sk-proj-xxxxxxxxxxxxx"
// }
//
// Anthropic:
// {
//   "provider": "anthropic",
//   "api_key": "sk-ant-xxxxxxxxxxxxx"
// }
//
// Google:
// {
//   "provider": "google",
//   "api_key": "AIzaSyxxxxxxxxxxxxx"
// }
//
// Mistral:
// {
//   "provider": "mistral",
//   "api_key": "xxxxxxxxxxxxx"
// }
//
// Groq:
// {
//   "provider": "groq",
//   "api_key": "gsk_xxxxxxxxxxxxx"
// }
//
// To use: Copy this file to auth.conf and replace with your actual API key
